@model CineScope.Models.Movie

@{
    ViewData["Title"] = "Edit Movie";
}

<h1>Edit Movie</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Genre" class="form-label"></label>
                <input asp-for="Genre" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="ReleaseYear" class="form-label"></label>
                <input asp-for="ReleaseYear" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Rating" class="form-label"></label>
                <input asp-for="Rating" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Duration" class="form-label"></label>
                <input asp-for="Duration" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="PosterUrl" class="form-label"></label>
                <input asp-for="PosterUrl" class="form-control" />
                @if (!string.IsNullOrEmpty(Model.PosterUrl))
                {
                    <div class="mt-2">
                        <img src="@Model.PosterUrl" class="img-thumbnail" style="width:120px;"
                             alt="Current poster for @Model.Title" />
                    </div>
                }
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
