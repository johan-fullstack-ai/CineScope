@model IEnumerable<CineScope.Models.Movie>

@{
    ViewData["Title"] = "Movies";
}

<h1>Movies</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="searchString" class="form-control" placeholder="Search by title"
               value="@ViewData["CurrentFilter"]" aria-label="Search by title" />
        <button type="submit" class="btn btn-primary">Search</button>
    </form>
    <a asp-action="Create" class="btn btn-success">Create New Movie</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Title</th>
            <th>Genre</th>
            <th>Release Year</th>
            <th>Rating</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5">
                    <div class="alert alert-info mb-0" role="alert">No movies found.</div>
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            @if (!string.IsNullOrEmpty(item.PosterUrl))
                            {
                                <img src="@item.PosterUrl" class="img-thumbnail" style="width:60px;"
                                     alt="Poster for @item.Title" />
                            }
                            @item.Title
                        </div>
                    </td>
                    <td>@item.Genre</td>
                    <td>@item.ReleaseYear</td>
                    <td>@item.Rating</td>
                    <td>
                        <div class="btn-group" role="group" aria-label="Actions for @item.Title">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary" aria-label="Edit @item.Title">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary" aria-label="Details for @item.Title">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger" aria-label="Delete @item.Title">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
